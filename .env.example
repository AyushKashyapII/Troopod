# Client: set false to call live OpenAI (requires OPENAI_API_KEY on the server)
VITE_USE_MOCK_AI=false

# Server (Express local + Vercel serverless): required for real vision + HTML generation
OPENAI_API_KEY=

# Optional: persistent public pages on Vercel (recommended for production)
BLOB_READ_WRITE_TOKEN=

# Optional: canonical origin for publish links when using in-memory store (e.g. https://admatch.app)
PUBLIC_APP_URL=
